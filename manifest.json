ס שלישי"], "correct": "רשימות תיוג מכניות"}, {"q": "מיקומם ותפקודם של ארבעת תאי הלב הנם כדלקמן:", "answers": ["הפרוזדור בצד ימין והחדרים בצד שמאל. הצד הימני מזרים דם עני בחמצן לריאות והצד השמאלי מזרימו לגוף", "הפרוזדור משמאל והחדרים מימין. הצד הימני מזרים דם עני בחמצן לריאות והצד השמאלי מזרימו לגוף", "הפרוזדורים הנם ימני ושמאלי והחדרים הנם ימני ושמאלי. הצד הימני מזרים דם עני בחמצן מתאי הגוף לריאות לצורך העשרתו בחמצן והצד השמאלי מקבל דם עשיר בחמצן מהריאות ומזרימו לגוף", "הפרוזדורים הנם ימני ושמאלי והחדרים הנם ימני ושמאלי. הצד השמאלי מזרים דם עני בחמצן מתאי הגוף לריאות לצורך העשרתו בחמצן והצד הימני מקבל דם עשיר בחמצן מהריאות ומזרימו לגוף"], "correct": "הפרוזדורים הנם ימני ושמאלי והחדרים הנם ימני ושמאלי. הצד הימני מזרים דם עני בחמצן מתאי הגוף לריאות לצורך העשרתו בחמצן והצד השמאלי מקבל דם עשיר בחמצן מהריאות ומזרימו לגוף", "num": 138}, {"q": "אלו מהבאים קשורים להטיית (Bias) תהליך קבלת החלטות? 1.חוויה אישית נוטה לשנות את תפיסת הסיכון 2.יש נטייה טבעית לדבוק בהחלטה שקיבלנו גם אם העובדות סותרות אותה 3.הקבוצה אליה משתייך מקבל ההחלטה נוטה להשפיע על החלטה 4.יש נטייה טבעית לבחור רק עובדות אובייקטיביות", "answers": ["1, 2, 3", "1, 2, 4", "1, 3, 4", "2, 3, 4"], "correct": "1, 2, 3", "num": 139}, {"q": "אם ידוע כי בשדה מסוים צפויה אשליית ראייה, כקברניט המטוס עליך:", "answers": ["לא לומר דבר כי זה עלול להבהיל את הצוות", "לוודא שתדרכת את הצוות", "לדווח למרכז המבצעים של חברתך כדי שגם צוותים אחרים יהיו מודעים לסכנה", "לדווח להנהלת החברה כדי שגם צוותים אחרים יהיו מודעים לסכנה"], "correct": "לוודא שתדרכת את הצוות", "num": 140}];

// STATE
let QQ=[],ci=0,UA={};
let bookmarks=new Set(JSON.parse(localStorage.getItem('bm')||'[]'));
let notes=JSON.parse(localStorage.getItem('notes')||'{}');
let wrongH=new Set(JSON.parse(localStorage.getItem('wh')||'[]'));
let corrH=new Set(JSON.parse(localStorage.getItem('ac')||'[]'));
let hist=JSON.parse(localStorage.getItem('sh')||'[]');
let curMode='all';
let opts={shuffle:true,qnum:false,timer:true};
let swSec=0,swRunning=false,swInt=null;
const MOCK_TOTAL=3600;
let mockRemain=MOCK_TOTAL,mockInt=null;

// ── STOPWATCH ──
function swTick(){swSec++;const m=String(Math.floor(swSec/60)).padStart(2,'0'),s=String(swSec%60).padStart(2,'0');document.getElementById('sw-disp').textContent=m+':'+s;}
function swToggle(){
  if(swRunning){clearInterval(swInt);swRunning=false;document.getElementById('sw-tog').textContent='▶ המשך';document.getElementById('sw-tog').classList.remove('running');}
  else{swInt=setInterval(swTick,1000);swRunning=true;document.getElementById('sw-tog').textContent='⏸ עצור';document.getElementById('sw-tog').classList.add('running');}
}
function swReset(){clearInterval(swInt);swRunning=false;swSec=0;document.getElementById('sw-disp').textContent='00:00';document.getElementById('sw-tog').textContent='▶ התחל';document.getElementById('sw-tog').classList.remove('running');}

// ── MOCK COUNTDOWN ──
function mockTick(){
  mockRemain--;
  const m=String(Math.floor(mockRemain/60)).padStart(2,'0'),s=String(mockRemain%60).padStart(2,'0');
  document.getElementById('mock-disp').textContent=m+':'+s;
  document.getElementById('mock-prog-fill').style.width=(mockRemain/MOCK_TOTAL*100)+'%';
  if(mockRemain<=600){
    document.getElementById('mock-disp').style.color='#fca5a5';
    document.getElementById('mock-warn').style.display='block';
  }
  if(mockRemain<=0){clearInterval(mockInt);mockInt=null;toast('הזמן נגמר! 🛬');finishQuiz();}
}
function startMockTimer(){
  clearInterval(mockInt);
  mockRemain=MOCK_TOTAL;
  document.getElementById('mock-disp').textContent='60:00';
  document.getElementById('mock-disp').style.color='var(--gold)';
  document.getElementById('mock-prog-fill').style.width='100%';
  document.getElementById('mock-warn').style.display='none';
  mockInt=setInterval(mockTick,1000);
}
function stopMockTimer(){clearInterval(mockInt);mockInt=null;}

function swAutoStart(){
  swReset();
  document.getElementById('sw-bar').style.display=(curMode!=='mock'&&opts.timer)?'flex':'none';
  document.getElementById('mock-timer-bar').style.display=(curMode==='mock')?'block':'none';
  if(curMode==='mock'){startMockTimer();}
  else if(opts.timer){swToggle();}
}
function fmtTime(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}

// ── TABS ──
function showTab(t){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('page-'+t).classList.add('on');
  const m={home:0,quiz:1,results:1,history:2,editor:3};
  if(m[t]!=null)document.querySelectorAll('.tab')[m[t]].classList.add('on');
  if(t==='editor')renderEditor();
  if(t==='history')renderHist();
  if(t==='home')updateHome();
}

// ── QUIZ ──
function shuf(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

function startQuiz(mode){
  curMode=mode;UA={};ci=0;
  let pool=[...QUESTIONS];
  if(mode==='wrong'){pool=QUESTIONS.filter(q=>wrongH.has(q.num));if(!pool.length){toast('אין שאלות שטעית עדיין!');return;}}
  if(mode==='bookmarks'){pool=QUESTIONS.filter(q=>bookmarks.has(q.num));if(!pool.length){toast('אין שאלות מסומנות!');return;}}
  if(mode==='unanswered'){const d=new Set([...wrongH,...corrH]);pool=QUESTIONS.filter(q=>!d.has(q.num));if(!pool.length){toast('ענית על כל השאלות!');return;}}
  if(mode==='random'||mode==='mock')pool=shuf(pool);
  if(mode==='mock')pool=pool.slice(0,30);
  QQ=pool;
  swAutoStart();
  showTab('quiz');
  buildNavGrid();
  renderQ();
}

function renderQ(){
  const q=QQ[ci];if(!q){finishQuiz();return;}
  const tot=QQ.length;
  // progress
  const ans=Object.values(UA).filter(v=>v&&v!=='sk').length;
  document.getElementById('prog').style.width=(ans/tot*100)+'%';
  document.getElementById('qctr').textContent=`שאלה ${ci+1} מתוך ${tot}`;
  document.getElementById('qnbadge').textContent=`מס׳ ${q.num}`;
  document.getElementById('qnbadge').style.display=opts.qnum?'inline-block':'none';
  document.getElementById('sw-bar').style.display=(curMode!=='mock'&&opts.timer)?'flex':'none';
  document.getElementById('mock-timer-bar').style.display=(curMode==='mock')?'block':'none';
  // bookmark
  const bb=document.getElementById('bmbtn');
  bb.style.filter=bookmarks.has(q.num)?'none':'grayscale(1)';
  // question
  document.getElementById('qtext').textContent=q.q;
  // note
  document.getElementById('note-inp').value=notes[q.num]||'';
  document.getElementById('note-sec').classList.remove('show');
  // answers
  let ans_arr=[...q.answers];
  if(opts.shuffle)ans_arr=shuf(ans_arr);
  const grid=document.getElementById('ans-grid');
  grid.innerHTML='';
  ans_arr.forEach((a,i)=>{
    const btn=document.createElement('button');
    btn.className='ans-btn';
    btn.innerHTML=`<span class="aletter">${LETTERS[i]}</span><span>${a}</span>`;
    btn.onclick=()=>selectA(a,btn,ans_arr);
    grid.appendChild(btn);
  });
  // feedback
  document.getElementById('fb').className='fb';
  // next/finish
  const nb=document.getElementById('next-btn'),fb2=document.getElementById('fin-btn');
  const isLast=ci===tot-1;
  const ua=UA[ci];
  if(ua&&ua!=='sk'){
    if(curMode==='mock'){
      document.querySelectorAll('.ans-btn').forEach(b=>{b.disabled=true;});
      document.getElementById('fb').className='fb';
    }else{
      disableA(ua.answer,ans_arr);showFb(ua.correct);
    }
    nb.style.display=isLast?'none':'inline-block';
    fb2.style.display=isLast?'inline-block':'none';
  }else{nb.style.display='none';fb2.style.display='none';}
  updNav();
}

function selectA(answer,btn,all){
  if(UA[ci]&&UA[ci]!=='sk')return;
  const q=QQ[ci];const ok=answer===q.correct;
  UA[ci]={answer,correct:ok};
  if(ok){corrH.add(q.num);wrongH.delete(q.num);}else wrongH.add(q.num);
  persist();updHdrScore();
  if(curMode==='mock'){
    // mock: just disable buttons, no colors, no feedback
    document.querySelectorAll('.ans-btn').forEach(b=>{b.disabled=true;});
    document.getElementById('fb').className='fb';
  }else{
    disableA(answer,all);showFb(ok);
  }
  const isLast=ci===QQ.length-1;
  document.getElementById('next-btn').style.display=isLast?'none':'inline-block';
  document.getElementById('fin-btn').style.display=isLast?'inline-block':'none';
  updNav();
}

function disableA(sel,all){
  const q=QQ[ci];
  document.querySelectorAll('.ans-btn').forEach(b=>{
    b.disabled=true;
    const t=b.querySelector('span:last-child').textContent;
    if(t===sel)b.classList.add(t===q.correct?'correct':'wrong');
    else if(t===q.correct)b.classList.add('show-correct');
  });
}

function showFb(ok){
  const fb=document.getElementById('fb'),q=QQ[ci];
  const exp=q.explanation&&q.explanation.trim();
  const expHtml=exp?`<div style="margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,.1);font-size:12px;font-weight:400;line-height:1.6;color:rgba(255,255,255,.85)"><span style="font-weight:700;color:var(--gold)">💡 הסבר: </span>${exp}</div>`:'';
  if(ok){
    fb.className='fb show ok';
    document.getElementById('fb-ico').textContent='✅';
    document.getElementById('fb-txt').innerHTML='תשובה נכונה! כל הכבוד.'+expHtml;
  }else{
    fb.className='fb show no';
    document.getElementById('fb-ico').textContent='❌';
    document.getElementById('fb-txt').innerHTML='תשובה שגויה. הנכונה: <strong>'+q.correct+'</strong>'+expHtml;
  }
}

function nextQ(){saveNote();ci++;renderQ();}
function prevQ(){saveNote();if(ci>0){ci--;renderQ();}}
function skipQ(){if(!UA[ci])UA[ci]='sk';updNav();ci++;if(ci>=QQ.length)finishQuiz();else renderQ();}
function finishQuiz(){saveNote();if(swRunning)swToggle();stopMockTimer();showResults();}

function saveNote(){
  const q=QQ[ci];if(!q)return;
  const v=document.getElementById('note-inp').value.trim();
  if(v)notes[q.num]=v;else delete notes[q.num];
  localStorage.setItem('notes',JSON.stringify(notes));
}
function toggleNote(){document.getElementById('note-sec').classList.toggle('show');if(document.getElementById('note-sec').classList.contains('show'))document.getElementById('note-inp').focus();}
function toggleBm(){const q=QQ[ci];if(!q)return;bookmarks.has(q.num)?bookmarks.delete(q.num):bookmarks.add(q.num);persist();renderQ();updateHome();}

// NAVIGATOR
function buildNavGrid(){
  const g=document.getElementById('qnav-grid');g.innerHTML='';
  QQ.forEach((q,i)=>{
    const b=document.createElement('button');
    b.className='qnb';b.id='nb-'+i;b.textContent=i+1;
    b.title=q.q.substring(0,50);
    b.onclick=()=>{saveNote();ci=i;renderQ();};
    if(bookmarks.has(q.num))b.classList.add('nbm');
    g.appendChild(b);
  });
}
function updNav(){
  QQ.forEach((q,i)=>{
    const b=document.getElementById('nb-'+i);if(!b)return;
    b.className='qnb';
    if(i===ci)b.classList.add('cur');
    const ua=UA[i];
    if(ua&&ua!=='sk'){
      if(curMode==='mock')b.classList.add('na');
      else b.classList.add(ua.correct?'nc':'nw');
    }else if(ua==='sk')b.classList.add('ns');
    if(bookmarks.has(q.num))b.classList.add('nbm');
  });
}

// OPTIONS
function toggleOpt(k){
  opts[k]=!opts[k];
  document.getElementById('p-'+k).classList.toggle('on',opts[k]);
  if(k==='timer')document.getElementById('sw-bar').style.display=(curMode!=='mock'&&opts.timer)?'flex':'none';
  document.getElementById('mock-timer-bar').style.display=(curMode==='mock')?'block':'none';
  if(k==='qnum')document.getElementById('qnbadge').style.display=(opts.qnum&&QQ.length)?'inline-block':'none';
}

function updHdrScore(){
  const vs=Object.values(UA).filter(v=>v&&v!=='sk');
  const ok=vs.filter(v=>v.correct).length;
  document.getElementById('hdr-score').textContent=vs.length?Math.round(ok/vs.length*100)+'%':'—';
}

// ── RESULTS ──
let revData=[];
function showResults(){
  document.getElementById('page-quiz').classList.remove('on');
  document.getElementById('page-results').classList.add('on');
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.tab')[1].classList.add('on');
  let c=0,w=0,s=0;
  QQ.forEach((_,i)=>{const ua=UA[i];if(!ua||ua==='sk')s++;else if(ua.correct)c++;else w++;});
  const ans=c+w,pct=ans>0?Math.round(c/ans*100):0,pass=pct>=75;
  document.getElementById('res-pct').textContent=pct+'%';
  document.getElementById('res-verdict').textContent=pass?'✈️ עבר':'📚 לא עבר';
  document.getElementById('res-circle').className='res-circle '+(pass?'pass':'fail');
  document.getElementById('res-title').textContent=pass?'!כל הכבוד, עברת!':'צריך עוד תרגול';
  document.getElementById('res-sub').textContent=`${c} מתוך ${ans} תשובות נכונות`;
  document.getElementById('res-time').textContent=`⏱ זמן: ${fmtTime(swSec)}`;
  document.getElementById('rc').textContent=c;document.getElementById('rw').textContent=w;document.getElementById('rs').textContent=s;
  hist.unshift({date:new Date().toLocaleDateString('he-IL'),mode:curMode,pct,correct:c,wrong:w,skipped:s,total:QQ.length,time:fmtTime(swSec)});
  if(hist.length>50)hist=hist.slice(0,50);
  localStorage.setItem('sh',JSON.stringify(hist));
  revData=QQ.map((q,i)=>{const ua=UA[i];return{q,i,status:!ua||ua==='sk'?'skipped':ua.correct?'correct':'wrong',your:ua&&ua!=='sk'?ua.answer:null,note:notes[q.num]||null};});
  buildRev('all');
}

function buildRev(flt){
  const list=document.getElementById('rev-list');list.innerHTML='';
  const items=flt==='all'?revData:revData.filter(r=>r.status===flt);
  if(!items.length){list.innerHTML='<div style="text-align:center;padding:22px;color:var(--muted);font-size:13px">אין פריטים</div>';return;}
  items.forEach(({q,i,status,your,note})=>{
    const cls=status==='correct'?'ok':status==='wrong'?'no':'sk';
    const badge=`<span class="rbadge ${cls}">${status==='correct'?'✓ נכון':status==='wrong'?'✗ שגוי':'דולג'}</span>`;
    const d=document.createElement('div');
    d.className='rev-item '+cls;
    d.innerHTML=`<div class="rev-hdr"><div class="rev-q">${i+1}. ${q.q}</div>${badge}</div>
      <div class="rev-detail" id="rd-${i}">
        ${your&&your!==q.correct?`<div class="ra wrong-a">❌ תשובתך: ${your}</div>`:''}
        <div class="ra right-a">✅ תשובה נכונה: ${q.correct}</div>
        ${note?`<div class="ra note-a">💡 ${note}</div>`:''}
      </div>`;
    d.onclick=()=>document.getElementById('rd-'+i).classList.toggle('open');
    list.appendChild(d);
  });
}

function filterRev(f,btn){document.querySelectorAll('.rev-filters .tpill').forEach(b=>b.classList.remove('on'));btn.classList.add('on');buildRev(f);}
function restartQ(){startQuiz(curMode);}

// ── HISTORY ──
function renderHist(){
  const l=document.getElementById('hist-list');
  if(!hist.length){l.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-size:14px">עוד לא ביצעת מבחנים. התחל לתרגל!</div>';return;}
  l.innerHTML='';
  hist.forEach(h=>{
    const pass=h.pct>=75;
    const d=document.createElement('div');d.className='hi';
    d.innerHTML=`<div><div class="hi-score ${pass?'pass':'fail'}">${h.pct}%</div><div class="hi-meta">${h.date} · ${MODE_NAMES[h.mode]||h.mode}</div></div>
      <div class="hi-detail">✅${h.correct} ❌${h.wrong} ⏭${h.skipped}<br>📋${h.total} שאלות &nbsp;⏱${h.time}</div>`;
    l.appendChild(d);
  });
}
function clearHist(){if(!confirm('למחוק את כל ההיסטוריה?'))return;hist=[];localStorage.setItem('sh','[]');renderHist();}

// ── PERSIST ──
function persist(){localStorage.setItem('bm',JSON.stringify([...bookmarks]));localStorage.setItem('wh',JSON.stringify([...wrongH]));localStorage.setItem('ac',JSON.stringify([...corrH]));}

function updateHome(){
  document.getElementById('h-total').textContent=QUESTIONS.length;
  document.getElementById('h-correct').textContent=corrH.size;
  document.getElementById('h-wrong').textContent=wrongH.size;
  document.getElementById('h-bm').textContent=bookmarks.size;
  document.getElementById('hdr-total').textContent=QUESTIONS.length;
}

// ── EDITOR ──
function renderEditor(){
  const l=document.getElementById('ed-list');l.innerHTML='';
  QUESTIONS.forEach((q,i)=>l.appendChild(buildEI(q,i)));
}
function buildEI(q,i){
  const d=document.createElement('div');d.className='ei';d.id='ei-'+i;
  const ah=q.answers.map((a,ai)=>`<div class="arow"><input type="radio" name="cr-${i}" value="${ai}" ${a===q.correct?'checked':''}><input class="finput ai-${i}" type="text" value="${escHtml(a)}" placeholder="תשובה ${ai+1}"><button onclick="rmA(${i},${ai})" style="background:none;border:none;color:#f87171;cursor:pointer;font-size:14px;padding:3px">✕</button></div>`).join('');
  const hasExp=q.explanation&&q.explanation.trim();
  d.innerHTML=`<div class="ei-hdr" onclick="togEI(${i})">
    <span class="ei-qnum">${q.num}</span>
    <span class="ei-prev">${q.q.substring(0,65)}${q.q.length>65?'...':''}</span>
    <span style="display:flex;align-items:center;gap:5px">${hasExp?'<span title="יש הסבר" style="font-size:13px">💡</span>':''}<span class="ei-arr">▼</span></span>
  </div>
  <div class="ei-form">
    <div class="fg"><label class="flbl">טקסט השאלה</label><textarea class="finput qt-${i}" rows="3">${escHtml(q.q)}</textarea></div>
    <div class="fg"><label class="flbl">תשובות (סמן ✓ נכונה)</label><div class="ae" id="ae-${i}">${ah}</div>
      <button onclick="addA(${i})" style="margin-top:5px;background:rgba(255,255,255,.04);border:1px dashed rgba(255,255,255,.14);color:var(--muted);padding:4px 11px;border-radius:5px;cursor:pointer;font-family:Heebo,sans-serif;font-size:11px;width:100%">+ תשובה</button></div>
    <div class="fg" style="border:1px solid rgba(240,180,41,.25);border-radius:10px;padding:12px;background:rgba(240,180,41,.04)">
      <label class="flbl" style="color:var(--gold)">💡 הסבר לתשובה הנכונה</label>
      <textarea class="finput exp-${i}" rows="4" placeholder="הכנס כאן הסבר מפורט לתשובה הנכונה. ניתן להעתיק מהמצגת או לכתוב בחופשי...">${escHtml(q.explanation||'')}</textarea>
      <div style="font-size:10px;color:var(--muted);margin-top:4px;text-align:right">ההסבר יוצג לאחר מענה על השאלה בתרגול רגיל</div>
    </div>
    <div class="ei-acts"><button class="btn-del" onclick="delQ(${i})">🗑 מחק</button><button class="btn-green" onclick="saveQ(${i})">💾 שמור</button></div>
  </div>`;
  return d;
}
function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function togEI(i){document.getElementById('ei-'+i).classList.toggle('open');}
function saveQ(i){
  const qt=document.querySelector(`.qt-${i}`).value.trim();
  const inputs=document.querySelectorAll(`.ai-${i}`);
  const radios=document.querySelectorAll(`input[name="cr-${i}"]`);
  let ci2=0;radios.forEach((r,j)=>{if(r.checked)ci2=j;});
  const answers=Array.from(inputs).map(x=>x.value.trim()).filter(Boolean);
  if(!answers.length||!qt){toast('❌ חסרים נתונים');return;}
  QUESTIONS[i].q=qt;QUESTIONS[i].answers=answers;QUESTIONS[i].correct=answers[ci2]||answers[0];
  const exp=document.querySelector(`.exp-${i}`)?.value.trim();
  QUESTIONS[i].explanation=exp||'';
  renderEditor();toast('✅ נשמר!');updateHome();
}
function delQ(i){if(!confirm('למחוק?'))return;QUESTIONS.splice(i,1);renderEditor();updateHome();toast('🗑 נמחק');}
function addA(i){const c=document.getElementById('ae-'+i),ai=c.children.length;const r=document.createElement('div');r.className='arow';r.innerHTML=`<input type="radio" name="cr-${i}" value="${ai}"><input class="finput ai-${i}" type="text" value="" placeholder="תשובה חדשה"><button onclick="this.parentElement.remove()" style="background:none;border:none;color:#f87171;cursor:pointer;font-size:14px;padding:3px">✕</button>`;c.appendChild(r);}
function rmA(i,ai){const c=document.getElementById('ae-'+i);if(c.children.length<=2){toast('❌ לפחות 2 תשובות');return;}c.children[ai].remove();}
function addNewQ(){QUESTIONS.push({num:QUESTIONS.length+1,q:'שאלה חדשה',answers:['תשובה א','תשובה ב','תשובה ג','תשובה ד'],correct:'תשובה א'});renderEditor();const last=QUESTIONS.length-1;setTimeout(()=>{document.getElementById('ei-'+last)?.classList.add('open');document.getElementById('ei-'+last)?.scrollIntoView({behavior:'smooth'});},100);updateHome();}
function exportQ(){const b=new Blob([JSON.stringify(QUESTIONS,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='aviation-questions.json';a.click();toast('💾 ייוצא!');}

// ── TOAST ──
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2400);}


// ── COUNT MODAL ──
let modalMode='all', modalMax=140, modalCount=20;

function openCountModal(mode){
  modalMode=mode;
  let pool=[...QUESTIONS];
  if(mode==='random') pool=shuf(pool);
  modalMax=pool.length;
  modalCount=Math.min(20,modalMax);
  document.getElementById('modal-title').textContent=mode==='all'?'כל השאלות – כמה לתרגל?':'סדר אקראי – כמה שאלות?';
  document.getElementById('modal-max-lbl').textContent='סה"כ זמין: '+modalMax+' שאלות';
  document.getElementById('count-display').textContent=modalCount;
  document.getElementById('count-modal').style.display='flex';
}
function closeCountModal(){document.getElementById('count-modal').style.display='none';}
function changeCount(d){setCount(modalCount+d);}
function setCount(n){modalCount=Math.max(1,Math.min(modalMax,n));document.getElementById('count-display').textContent=modalCount;}
function setCountAll(){setCount(modalMax);}
function confirmCountModal(){
  closeCountModal();
  curMode=modalMode;UA={};ci=0;
  let pool=[...QUESTIONS];
  if(modalMode==='random') pool=shuf(pool);
  pool=pool.slice(0,modalCount);
  QQ=pool;
  swAutoStart();
  showTab('quiz');
  buildNavGrid();
  renderQ();
}

// INIT
updateHome();
</script>

<!-- QUESTION COUNT MODAL -->
<div id="count-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;align-items:center;justify-content:center;">
  <div style="background:#0d2045;border:1px solid rgba(240,180,41,.3);border-radius:16px;padding:28px 24px;width:320px;max-width:90vw;text-align:center;">
    <div style="font-size:24px;margin-bottom:10px;">🎯</div>
    <h3 id="modal-title" style="font-size:17px;font-weight:800;color:var(--gold);margin-bottom:6px;">כמה שאלות?</h3>
    <p style="font-size:12px;color:var(--muted);margin-bottom:18px;" id="modal-max-lbl">בחר מספר שאלות</p>
    <div style="display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:20px;">
      <button onclick="changeCount(-10)" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:white;border-radius:8px;width:36px;height:36px;font-size:16px;font-weight:700;cursor:pointer;">-10</button>
      <button onclick="changeCount(-1)" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:white;border-radius:8px;width:36px;height:36px;font-size:18px;font-weight:700;cursor:pointer;">−</button>
      <span id="count-display" style="font-size:36px;font-weight:900;color:var(--white);min-width:60px;">20</span>
      <button onclick="changeCount(1)" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:white;border-radius:8px;width:36px;height:36px;font-size:18px;font-weight:700;cursor:pointer;">+</button>
      <button onclick="changeCount(10)" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:white;border-radius:8px;width:36px;height:36px;font-size:16px;font-weight:700;cursor:pointer;">+10</button>
    </div>
    <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
      <button onclick="setCount(10)" class="tpill">10</button>
      <button onclick="setCount(20)" class="tpill">20</button>
      <button onclick="setCount(30)" class="tpill">30</button>
      <button onclick="setCount(50)" class="tpill">50</button>
      <button onclick="setCountAll()" class="tpill">הכל</button>
    </div>
    <div style="display:flex;gap:8px;">
      <button onclick="closeCountModal()" class="btn btn-ghost" style="flex:1">ביטול</button>
      <button onclick="confirmCountModal()" class="btn btn-gold" style="flex:2">התחל ✈️</button>
    </div>
  </div>
</div>

<script>
if('serviceWorker' in navigator){
  window.addEventListener('load', ()=>{
    navigator.serviceWorker.register('./sw.js')
      .then(()=>console.log('SW registered'))
      .catch(e=>console.log('SW error',e));
  });
}
</script>
</body>
</html>
