<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ביצועי אנוש – ATPL</title>
<meta name="theme-color" content="#0d2045">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ATPL">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --sky:#0a1628;--white:#ffffff;--gold:#f0b429;--green:#22c55e;
    --red:#ef4444;--blue:#60a5fa;--muted:#8fadc8;--orange:#f97316;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Heebo',sans-serif;background:var(--sky);color:var(--white);min-height:100vh;direction:rtl;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(96,165,250,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 80%,rgba(240,180,41,.05) 0%,transparent 50%),linear-gradient(180deg,#0a1628 0%,#0d2045 40%,#1a3a6e 100%);z-index:-1;}
  body::after{content:'';position:fixed;inset:0;background-image:radial-gradient(1px 1px at 10% 15%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 30% 8%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1px 1px at 55% 5%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 75% 18%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 85% 10%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1px 1px at 50% 30%,rgba(255,255,255,.3) 0%,transparent 100%);z-index:-1;opacity:.7;}

  /* HEADER */
  .hdr{background:rgba(10,22,40,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(240,180,41,.3);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;}
  .hdr-title{display:flex;align-items:center;gap:10px;}
  .hdr-icon{font-size:26px;filter:drop-shadow(0 0 8px rgba(240,180,41,.6));}
  .hdr-text h1{font-size:16px;font-weight:800;color:var(--gold);line-height:1;}
  .hdr-text p{font-size:11px;color:var(--muted);margin-top:2px;}
  .hdr-right{display:flex;gap:8px;align-items:center;}
  .pill{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;}
  .pill span{color:var(--gold);}

  /* TABS */
  .tabs{display:flex;padding:10px 20px 0;gap:4px;border-bottom:1px solid rgba(255,255,255,.08);background:rgba(10,22,40,.5);}
  .tab{background:none;border:none;color:var(--muted);font-family:'Heebo',sans-serif;font-size:13px;font-weight:600;padding:8px 16px;cursor:pointer;border-radius:8px 8px 0 0;border-bottom:2px solid transparent;transition:all .2s;}
  .tab:hover{color:var(--white);background:rgba(255,255,255,.05);}
  .tab.on{color:var(--gold);border-bottom-color:var(--gold);background:rgba(240,180,41,.08);}

  /* PAGES */
  .page{display:none;}.page.on{display:block;}
  .wrap{max-width:1080px;margin:0 auto;padding:22px 20px;}

  /* BUTTONS */
  .btn{font-family:'Heebo',sans-serif;font-size:13px;font-weight:700;padding:9px 18px;border-radius:9px;border:none;cursor:pointer;transition:all .2s;}
  .btn-gold{background:linear-gradient(135deg,var(--gold),#ffd700);color:var(--sky);}
  .btn-gold:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(240,180,41,.4);}
  .btn-ghost{background:rgba(255,255,255,.06);color:var(--white);border:1px solid rgba(255,255,255,.12);}
  .btn-ghost:hover{background:rgba(255,255,255,.12);}
  .btn-skip{background:rgba(239,68,68,.13);color:#fca5a5;border:1px solid rgba(239,68,68,.3);font-size:12px;padding:7px 13px;}
  .btn-skip:hover{background:rgba(239,68,68,.22);}
  .btn-note{background:rgba(96,165,250,.1);color:var(--blue);border:1px solid rgba(96,165,250,.25);font-size:12px;padding:7px 13px;}
  .btn-note:hover{background:rgba(96,165,250,.2);}
  .btn-green{background:linear-gradient(135deg,var(--green),#16a34a);color:white;font-family:'Heebo',sans-serif;font-size:12px;font-weight:700;padding:7px 14px;border-radius:7px;border:none;cursor:pointer;}
  .btn-del{background:rgba(239,68,68,.15);color:#fca5a5;border:1px solid rgba(239,68,68,.3);font-family:'Heebo',sans-serif;font-size:12px;font-weight:700;padding:7px 12px;border-radius:7px;cursor:pointer;}
  .btn-del:hover{background:rgba(239,68,68,.25);}

  /* TOGGLE PILLS */
  .tpill{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:5px 12px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'Heebo',sans-serif;transition:all .2s;}
  .tpill.on{background:rgba(240,180,41,.2);border-color:rgba(240,180,41,.5);color:var(--gold);}

  /* HOME */
  .home-hero{text-align:center;padding:36px 0 24px;}
  .home-hero .plane{font-size:56px;filter:drop-shadow(0 0 20px rgba(240,180,41,.5));margin-bottom:14px;display:block;}
  .home-hero h2{font-size:28px;font-weight:900;margin-bottom:7px;background:linear-gradient(135deg,#fff,var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .home-hero p{font-size:14px;color:var(--muted);max-width:440px;margin:0 auto 26px;line-height:1.6;}
  .mode-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:22px;}
  .mcard{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:13px;padding:18px 14px;cursor:pointer;transition:all .2s;text-align:center;}
  .mcard:hover{background:rgba(255,255,255,.09);transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,0,0,.3);}
  .mcard .mi{font-size:30px;margin-bottom:8px;display:block;}
  .mcard h3{font-size:14px;font-weight:700;margin-bottom:4px;}
  .mcard p{font-size:11px;color:var(--muted);line-height:1.4;}
  .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
  .scard{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:11px;padding:14px;text-align:center;}
  .scard .n{font-size:26px;font-weight:900;color:var(--gold);}
  .scard .n.g{color:var(--green);}.scard .n.r{color:var(--red);}.scard .n.b{color:var(--blue);}
  .scard .l{font-size:11px;color:var(--muted);margin-top:3px;}

  /* QUIZ LAYOUT */
  .quiz-layout{display:grid;grid-template-columns:1fr 210px;gap:16px;align-items:start;}

  /* SIDEBAR NAV */
  .qnav{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:13px;padding:13px 11px;position:sticky;top:76px;max-height:calc(100vh - 96px);overflow-y:auto;}
  .qnav::-webkit-scrollbar{width:3px;}
  .qnav::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:2px;}
  .qnav-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px;padding-bottom:7px;border-bottom:1px solid rgba(255,255,255,.07);}
  .qnav-legend{display:flex;flex-direction:column;gap:3px;margin-bottom:9px;font-size:10px;color:var(--muted);}
  .qnav-legend-row{display:flex;align-items:center;gap:5px;}
  .ldot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
  .ldot.g{background:var(--green);}.ldot.r{background:var(--red);}.ldot.s{background:rgba(240,180,41,.6);}.ldot.u{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);}
  .qnav-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;}
  .qnb{aspect-ratio:1;border-radius:5px;border:1.5px solid rgba(255,255,255,.12);background:rgba(255,255,255,.05);color:var(--muted);font-family:'Heebo',sans-serif;font-size:10px;font-weight:700;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;}
  .qnb:hover{border-color:rgba(96,165,250,.5);color:var(--white);}
  .qnb.cur{border-color:var(--blue);background:rgba(96,165,250,.15);color:var(--white);}
  .qnb.nc{background:rgba(34,197,94,.25);border-color:rgba(34,197,94,.5);color:#86efac;}
  .qnb.nw{background:rgba(239,68,68,.22);border-color:rgba(239,68,68,.5);color:#fca5a5;}
  .qnb.ns{background:rgba(240,180,41,.15);border-color:rgba(240,180,41,.4);color:var(--gold);}
  .qnb.nbm{box-shadow:inset 0 0 0 2px var(--gold);}
  .qnb.na{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.35);color:var(--white);}

  /* STOPWATCH */
  .sw-bar{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:9px;padding:8px 13px;margin-bottom:13px;}
  .sw-time{font-size:22px;font-weight:800;font-variant-numeric:tabular-nums;letter-spacing:1px;color:var(--white);}
  .sw-lbl{font-size:10px;color:var(--muted);font-weight:600;margin-bottom:2px;}
  .sw-btns{display:flex;gap:5px;}
  .sw-btn{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);color:var(--white);border-radius:7px;padding:5px 10px;font-family:'Heebo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;}
  .sw-btn:hover{background:rgba(255,255,255,.14);}
  .sw-btn.running{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.4);color:#fca5a5;}

  /* PROGRESS */
  .prog-wrap{background:rgba(255,255,255,.1);border-radius:999px;height:5px;margin-bottom:13px;overflow:hidden;}
  .prog-fill{background:linear-gradient(90deg,var(--gold),#ffd700);height:100%;border-radius:999px;transition:width .4s ease;}
  .q-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px;font-size:12px;color:var(--muted);}
  .qnum-badge{background:linear-gradient(135deg,var(--gold),#ffd700);color:var(--sky);font-weight:800;font-size:10px;padding:3px 9px;border-radius:999px;}
  .bm-btn{background:none;border:none;cursor:pointer;font-size:18px;transition:all .2s;padding:2px;}
  .bm-btn:hover{transform:scale(1.1);}

  /* QUESTION */
  .qcard{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:13px;padding:20px 24px;margin-bottom:13px;backdrop-filter:blur(10px);}
  .qtext{font-size:17px;font-weight:600;line-height:1.65;}

  /* ANSWERS */
  .ans-grid{display:flex;flex-direction:column;gap:7px;}
  .ans-btn{background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 15px;color:var(--white);font-family:'Heebo',sans-serif;font-size:14px;font-weight:500;text-align:right;cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:10px;line-height:1.5;}
  .ans-btn:hover:not(:disabled){background:rgba(96,165,250,.15);border-color:rgba(96,165,250,.4);transform:translateX(-2px);}
  .aletter{width:26px;height:26px;min-width:26px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--muted);transition:all .18s;}
  .ans-btn.correct{background:rgba(34,197,94,.15);border-color:rgba(34,197,94,.6);color:#86efac;}
  .ans-btn.correct .aletter{background:var(--green);border-color:var(--green);color:white;}
  .ans-btn.wrong{background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.5);color:#fca5a5;}
  .ans-btn.wrong .aletter{background:var(--red);border-color:var(--red);color:white;}
  .ans-btn.show-correct{background:rgba(34,197,94,.08);border-color:rgba(34,197,94,.4);color:#86efac;}
  .ans-btn:disabled{cursor:default;}

  /* FEEDBACK */
  .fb{display:none;margin-top:11px;padding:11px 15px;border-radius:9px;font-size:13px;font-weight:600;align-items:center;gap:8px;}
  .fb.show{display:flex;}
  .fb.ok{background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.4);color:#86efac;}
  .fb.no{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.4);color:#fca5a5;}

  /* NOTE BOX */
  .note-section{display:none;margin-top:9px;animation:fadeIn .3s ease;}
  .note-section.show{display:block;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
  .note-box{background:rgba(96,165,250,.08);border:1px solid rgba(96,165,250,.2);border-radius:9px;padding:11px 14px;}
  .note-box .nlbl{font-size:10px;font-weight:700;color:rgba(96,165,250,.6);text-transform:uppercase;letter-spacing:.6px;margin-bottom:4px;}
  .note-box textarea{width:100%;background:transparent;border:none;outline:none;color:var(--blue);font-family:'Heebo',sans-serif;font-size:13px;resize:none;direction:rtl;line-height:1.6;}
  .note-box textarea::placeholder{color:rgba(96,165,250,.4);}

  /* NAV ROW */
  .nav-row{display:flex;gap:7px;margin-top:13px;justify-content:space-between;align-items:center;}

  /* TOP BAR */
  .top-bar{display:flex;gap:6px;margin-bottom:13px;flex-wrap:wrap;}

  /* RESULTS */
  .res-hero{text-align:center;padding:32px 0 20px;}
  .res-circle{width:148px;height:148px;border-radius:50%;margin:0 auto 16px;display:flex;flex-direction:column;align-items:center;justify-content:center;border:4px solid;}
  .res-circle.pass{border-color:var(--green);background:rgba(34,197,94,.1);box-shadow:0 0 36px rgba(34,197,94,.2);}
  .res-circle.fail{border-color:var(--red);background:rgba(239,68,68,.1);box-shadow:0 0 36px rgba(239,68,68,.2);}
  .res-pct{font-size:38px;font-weight:900;line-height:1;}
  .res-lbl{font-size:11px;color:var(--muted);margin-top:3px;}
  .res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin:18px 0 22px;}
  .rcard{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:11px;padding:15px;text-align:center;}
  .rcard .n{font-size:28px;font-weight:800;}.rcard .l{font-size:11px;color:var(--muted);margin-top:3px;}
  .rcard.g .n{color:var(--green);}.rcard.r .n{color:var(--red);}.rcard.b .n{color:var(--blue);}
  .rev-filters{display:flex;gap:5px;margin-bottom:10px;flex-wrap:wrap;}
  .rev-list{}
  .rev-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:9px;padding:12px 15px;margin-bottom:7px;cursor:pointer;transition:all .2s;}
  .rev-item:hover{background:rgba(255,255,255,.07);}
  .rev-item.ok{border-right:3px solid var(--green);}.rev-item.no{border-right:3px solid var(--red);}.rev-item.sk{border-right:3px solid var(--gold);}
  .rev-hdr{display:flex;justify-content:space-between;align-items:flex-start;gap:9px;}
  .rev-q{font-size:13px;font-weight:600;flex:1;line-height:1.4;}
  .rbadge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px;white-space:nowrap;}
  .rbadge.ok{background:rgba(34,197,94,.2);color:#86efac;}.rbadge.no{background:rgba(239,68,68,.2);color:#fca5a5;}.rbadge.sk{background:rgba(240,180,41,.2);color:var(--gold);}
  .rev-detail{display:none;margin-top:9px;padding-top:9px;border-top:1px solid rgba(255,255,255,.07);font-size:12px;line-height:1.6;}
  .rev-detail.open{display:block;}
  .ra{margin-bottom:3px;}.ra.wrong-a{color:#fca5a5;}.ra.right-a{color:#86efac;}.ra.note-a{color:var(--blue);margin-top:5px;font-style:italic;}

  /* HISTORY */
  .hist-list{display:flex;flex-direction:column;gap:7px;}
  .hi{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:9px;padding:12px 15px;display:flex;justify-content:space-between;align-items:center;}
  .hi-score{font-size:22px;font-weight:900;}.hi-score.pass{color:var(--green);}.hi-score.fail{color:var(--red);}
  .hi-meta{font-size:12px;color:var(--muted);margin-top:2px;}
  .hi-detail{font-size:11px;color:var(--muted);text-align:left;}

  /* EDITOR */
  .ed-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
  .ed-title{font-size:18px;font-weight:800;}.ed-sub{font-size:12px;color:var(--muted);margin-top:2px;}
  .ed-list{display:flex;flex-direction:column;gap:9px;}
  .ei{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;overflow:hidden;}
  .ei-hdr{padding:12px 15px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:background .2s;}
  .ei-hdr:hover{background:rgba(255,255,255,.04);}
  .ei-qnum{background:linear-gradient(135deg,var(--gold),#ffd700);color:var(--sky);font-weight:800;font-size:10px;padding:2px 8px;border-radius:999px;margin-left:8px;}
  .ei-prev{font-size:13px;font-weight:600;flex:1;color:var(--white);line-height:1.4;}
  .ei-arr{color:var(--muted);font-size:15px;transition:transform .2s;}
  .ei.open .ei-arr{transform:rotate(180deg);}
  .ei-form{display:none;padding:13px 15px 15px;border-top:1px solid rgba(255,255,255,.06);}
  .ei.open .ei-form{display:block;}
  .fg{margin-bottom:11px;}
  .flbl{display:block;font-size:11px;font-weight:700;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;}
  .finput{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:7px;padding:8px 11px;color:var(--white);font-family:'Heebo',sans-serif;font-size:13px;outline:none;transition:border-color .2s;direction:rtl;}
  .finput:focus{border-color:var(--gold);}
  .ae{display:flex;flex-direction:column;gap:5px;}
  .arow{display:flex;gap:6px;align-items:center;}
  .arow input[type="radio"]{accent-color:var(--green);}
  .ei-acts{display:flex;gap:6px;justify-content:flex-end;margin-top:11px;}
  .add-q-btn{width:100%;background:rgba(240,180,41,.07);border:2px dashed rgba(240,180,41,.3);border-radius:10px;padding:13px;color:var(--gold);font-family:'Heebo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:9px;}
  .add-q-btn:hover{background:rgba(240,180,41,.14);border-color:rgba(240,180,41,.6);}

  /* TOAST */
  .toast{position:fixed;bottom:18px;right:18px;background:rgba(34,197,94,.92);color:white;padding:9px 16px;border-radius:8px;font-weight:700;font-size:13px;transform:translateY(70px);opacity:0;transition:all .3s;z-index:999;}
  .toast.show{transform:translateY(0);opacity:1;}

  @media(max-width:700px){
    .quiz-layout{grid-template-columns:1fr;}
    .qnav{position:static;max-height:130px;}
    .qnav-grid{grid-template-columns:repeat(9,1fr);}
    .mode-grid{grid-template-columns:repeat(2,1fr);}
    .stat-grid{grid-template-columns:repeat(2,1fr);}
    .hdr-right .pill:last-child{display:none;}
  }
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-title">
    <span class="hdr-icon">✈️</span>
    <div class="hdr-text">
      <h1>ביצועי אנוש</h1>
      <p>פלטפורמת הכנה למבחן תיאורטי מסחרי</p>
    </div>
  </div>
  <div class="hdr-right">
    <div class="pill">שאלות: <span id="hdr-total">47</span></div>
    <div class="pill">ניקוד: <span id="hdr-score">—</span></div>
  </div>
</div>

<div class="tabs">
  <button class="tab on" onclick="showTab('home')">🏠 בית</button>
  <button class="tab" onclick="showTab('quiz')">📝 תרגול</button>
  <button class="tab" onclick="showTab('history')">📊 היסטוריה</button>
  <button class="tab" onclick="showTab('editor')">✏️ עריכה</button>
</div>

<!-- HOME -->
<div class="page on wrap" id="page-home">
  <div class="home-hero">
    <span class="plane">✈️</span>
    <h2>מוכן לטיסה?</h2>
    <p>התכונן למבחן התיאורטי ברשות התעופה האזרחית. תרגל שאלות, עקוב אחר ההתקדמות ושפר את ביצועיך.</p>
